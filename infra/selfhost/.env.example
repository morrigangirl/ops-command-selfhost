# Public domains exposed by your gateway
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
WEB_PORT=8200

# Cloudflare tunnel token (dashboard-managed tunnel)
CLOUDFLARE_TUNNEL_TOKEN=

# Local Supabase API port from `supabase start`
SUPABASE_API_PORT=55321

# Frontend build-time variables for Vite
VITE_SUPABASE_URL=https://api.example.com
VITE_SUPABASE_PUBLISHABLE_KEY=

# Comma-separated app origins for edge-function CORS checks.
# This value is consumed from supabase/functions/.env.local (documented in MIGRATION_PLAN.md).
ALLOWED_ORIGINS=https://app.example.com,http://localhost:8200
